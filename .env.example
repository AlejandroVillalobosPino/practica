# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Base de Datos (Sustituir por tu URL de Atlas)
MONGODB_URL=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/nombre_bd

# Seguridad (JWT)
JWT_SECRET=tu_secreto_super_seguro_para_firmar_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d